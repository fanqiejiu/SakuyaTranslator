<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MtTransTool.App.Dialogs.TypedConfirmDialog"
        Width="420"
        Height="322"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="确认删除"
        FontFamily="Inter, Microsoft YaHei UI, Segoe UI">
  <Window.Styles>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#D93F4A" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#D93F4A" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="14,6" />
    </Style>
    <Style Selector="Button.danger:pointerover">
      <Setter Property="Background" Value="#B92E39" />
      <Setter Property="BorderBrush" Value="#B92E39" />
    </Style>
    <Style Selector="TextBox.confirmInput">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="FontSize" Value="13" />
    </Style>
  </Window.Styles>

  <Border Background="{DynamicResource ContentBackgroundBrush}"
          BorderBrush="{DynamicResource BorderSoftBrush}"
          BorderThickness="1"
          Padding="18">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
      <TextBlock x:Name="TitleText"
                 FontSize="18"
                 FontWeight="SemiBold"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource TextPrimaryBrush}" />

      <Border Grid.Row="1"
              Background="#FFF1F2"
              BorderBrush="#FDA4AF"
              BorderThickness="1"
              CornerRadius="7"
              Padding="10">
        <StackPanel Spacing="4">
          <TextBlock Text="危险操作"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="#BE123C" />
          <TextBlock Text="该任务会从待翻译列表和打开记录中移除，但不会删除原始 JSON 文件。"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Foreground="#9F1239" />
        </StackPanel>
      </Border>

      <Border Grid.Row="2"
              Background="{DynamicResource SurfaceBrush}"
              BorderBrush="{DynamicResource BorderSoftBrush}"
              BorderThickness="1"
              CornerRadius="7"
              Padding="10">
        <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
          <TextBlock Text="将移除的任务"
                     FontSize="11"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <TextBlock x:Name="FileNameText"
                     Grid.Row="1"
                     FontSize="13"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
        </Grid>
      </Border>

      <StackPanel Grid.Row="3" Spacing="6">
        <TextBlock x:Name="InstructionText"
                   FontSize="12"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <TextBox x:Name="ConfirmInput"
                 Classes="confirmInput"
                 TextChanged="ConfirmInput_TextChanged" />
        <TextBlock x:Name="MatchHintText"
                   FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
      </StackPanel>

      <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
        <TextBlock Text="请确认后再操作。"
                   VerticalAlignment="Center"
                   FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <Button Grid.Column="1"
                Content="{DynamicResource dialog.cancel}"
                Padding="12,6"
                Click="Cancel_Click" />
        <Button x:Name="ConfirmButton"
                Grid.Column="2"
                Classes="danger"
                Content="确认删除"
                IsEnabled="False"
                Click="Confirm_Click" />
      </Grid>
    </Grid>
  </Border>
</Window>
