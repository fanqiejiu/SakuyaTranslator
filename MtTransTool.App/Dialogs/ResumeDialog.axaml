<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MtTransTool.App.Dialogs.ResumeDialog"
        Width="430"
        Height="250"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="检测到未完成任务"
        FontFamily="Inter, Microsoft YaHei UI, Segoe UI">
  <Grid Margin="18" RowDefinitions="Auto,*,Auto" RowSpacing="12">
    <TextBlock Text="检测到未完成任务" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
    <TextBlock x:Name="BodyText"
               Grid.Row="1"
               TextWrapping="Wrap"
               Foreground="{DynamicResource TextSecondaryBrush}" />
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="取消" Click="Cancel_Click" />
      <Button Content="只打开查看" Click="ViewOnly_Click" />
      <Button Content="重新开始" Click="Restart_Click" />
      <Button Content="继续进度" Click="Continue_Click" />
    </StackPanel>
  </Grid>
</Window>
