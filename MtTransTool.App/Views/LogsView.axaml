<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MtTransTool.App.Views.LogsView">
  <Grid RowDefinitions="Auto,*" Margin="8" RowSpacing="8">
    <Grid ColumnDefinitions="*,Auto">
      <TextBlock Text="{DynamicResource page.logs}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
      <Button Grid.Column="1" Content="{DynamicResource logs.clear}" Command="{Binding ClearCommand}" Padding="8,4" FontSize="12" />
    </Grid>
    <ListBox Grid.Row="1"
             ItemsSource="{Binding Lines}"
             Background="{DynamicResource SurfaceBrush}"
             BorderBrush="{DynamicResource BorderSoftBrush}"
             FontFamily="Consolas, Microsoft YaHei UI"
             FontSize="12" />
  </Grid>
</UserControl>
