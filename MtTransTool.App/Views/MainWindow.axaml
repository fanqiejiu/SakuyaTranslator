<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:MtTransTool.App.Controls"
        x:Class="MtTransTool.App.Views.MainWindow"
        Title="Sakuya Translator"
        Width="400"
        Height="600"
        MinWidth="400"
        MinHeight="600"
        CanResize="False"
        Icon="/Assets/app-icon.ico"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        FontFamily="Inter, Microsoft YaHei UI, Segoe UI">
  <Window.Styles>
    <Style Selector="Button.nav">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="Margin" Value="5,2" />
      <Setter Property="Padding" Value="2,6" />
      <Setter Property="MinHeight" Value="31" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.nav:pointerover">
      <Setter Property="Background" Value="{DynamicResource NavHoverBrush}" />
    </Style>
    <Style Selector="Button.nav:pressed">
      <Setter Property="Background" Value="{DynamicResource NavPressedBrush}" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="TextBox.compact">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.window">
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="22" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#E6EDF5" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.window:pointerover">
      <Setter Property="Background" Value="#4C48A8" />
    </Style>
    <Style Selector="ComboBox.statusModel">
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="Height" Value="22" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Padding" Value="5,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </Window.Styles>

  <Border Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="1">
  <Grid RowDefinitions="30,*,32" ColumnDefinitions="58,*">
    <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#312D87" BorderBrush="#4A46A8" BorderThickness="0,0,0,1" PointerPressed="TitleBar_PointerPressed">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" Margin="8,0,5,0" ColumnSpacing="5">
        <TextBlock Text="Sakuya Translator"
                   VerticalAlignment="Center"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="#E6EDF5" />
        <TextBlock Grid.Column="1"
                   Text="v0.1.0"
                   VerticalAlignment="Center"
                   FontSize="11"
                   Foreground="#C9D1FF" />
        <TextBlock Grid.Column="3"
                   Text="{Binding GlobalStatus}"
                   VerticalAlignment="Center"
                   FontSize="11"
                   Foreground="#C9D1FF" />
        <Button Grid.Column="4" Classes="window" Content="_" ToolTip.Tip="{DynamicResource window.minimize}" Click="Minimize_Click" />
        <Button Grid.Column="5" Classes="window" Content="X" ToolTip.Tip="{DynamicResource window.close}" Click="Close_Click" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,1,0">
      <ScrollViewer VerticalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,7,0,6">
          <Button Classes="nav" Content="{Binding NavQueue}" ToolTip.Tip="{DynamicResource nav.queue}" Command="{Binding NavigateCommand}" CommandParameter="Queue" />
          <Button Classes="nav" Content="{Binding NavManual}" ToolTip.Tip="{DynamicResource nav.manual}" Command="{Binding NavigateCommand}" CommandParameter="Manual" />
          <Button Classes="nav" Content="API" ToolTip.Tip="{Binding NavApi}" Command="{Binding NavigateCommand}" CommandParameter="Api" />
          <Button Classes="nav" Content="{DynamicResource nav.settings.short}" ToolTip.Tip="{Binding NavSettings}" Command="{Binding NavigateCommand}" CommandParameter="Settings" />
          <Button Classes="nav" Content="{Binding NavTemplates}" ToolTip.Tip="{DynamicResource nav.templates}" Command="{Binding NavigateCommand}" CommandParameter="Templates" />
          <Button Classes="nav" Content="{Binding NavLogs}" ToolTip.Tip="{DynamicResource nav.logs}" Command="{Binding NavigateCommand}" CommandParameter="Logs" />
          <Button Classes="nav" Content="{DynamicResource nav.about.short}" ToolTip.Tip="{Binding NavAbout}" Command="{Binding NavigateCommand}" CommandParameter="About" />
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource ContentBackgroundBrush}">
      <ContentControl Content="{Binding CurrentPage}" />
    </Border>

    <Border Grid.Row="2"
            Grid.ColumnSpan="2"
            Background="#40000000"
            BorderBrush="{DynamicResource BorderSoftBrush}"
            BorderThickness="0,1,0,0"
            Padding="6,4">
      <Grid ColumnDefinitions="Auto,Auto,*,62,30" ColumnSpacing="5">
        <TextBlock Text="{Binding DirectionText}" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock Grid.Column="1" Text="{Binding SpeedText}" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
        <Grid Grid.Column="2" ToolTip.Tip="{Binding CurrentModelDetail}">
          <Grid ColumnDefinitions="74,*" ColumnSpacing="4"
                IsVisible="{Binding IsTranslationModelSelectorEnabled}">
            <ComboBox Classes="statusModel"
                      ItemsSource="{Binding TranslationProviderOptions}"
                      SelectedItem="{Binding SelectedTranslationProvider}"
                      IsEnabled="{Binding IsTranslationProviderSelectorEnabled}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding DisplayName}"
                             TextTrimming="CharacterEllipsis" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox Grid.Column="1"
                      Classes="statusModel"
                      ItemsSource="{Binding TranslationModelOptions}"
                      SelectedItem="{Binding SelectedTranslationModel}"
                      IsEnabled="{Binding IsTranslationModelSelectorEnabled}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding DisplayName}"
                             TextTrimming="CharacterEllipsis" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
          <TextBlock Text="{Binding CurrentModel}"
                     IsVisible="{Binding IsTranslationModelFallbackVisible}"
                     VerticalAlignment="Center"
                     FontSize="11"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     TextTrimming="CharacterEllipsis" />
        </Grid>
        <controls:PipeProgressBar Grid.Column="3" Value="{Binding TotalProgress}" ShowPercent="False" Height="14" VerticalAlignment="Center" />
        <TextBlock Grid.Column="4" Text="{Binding TotalProgressText}" VerticalAlignment="Center" TextAlignment="Right" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" />
      </Grid>
    </Border>
  </Grid>
  </Border>
</Window>
