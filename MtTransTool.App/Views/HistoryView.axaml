<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MtTransTool.App.Views.HistoryView">
  <Grid Margin="8" RowDefinitions="Auto,Auto,*" RowSpacing="8">
    <TextBlock Text="{DynamicResource page.history}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
    <TextBlock Grid.Row="1"
               Text="{Binding StatusText}"
               FontSize="12"
               Foreground="{DynamicResource TextSecondaryBrush}"
               TextWrapping="Wrap" />
    <TabControl Grid.Row="2">
      <TabItem Header="{DynamicResource history.ongoing}">
        <ListBox ItemsSource="{Binding OngoingJobs}" Margin="0,10,0,0">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Padding="8" Margin="0,0,0,8" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="6">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <StackPanel>
                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding StatusLine}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding ModelText}" ToolTip.Tip="{Binding ModelText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="5">
                    <Button Content="{DynamicResource history.continue}" Click="ContinueRecord_Click" Padding="8,4" FontSize="12" />
                    <Button Content="{DynamicResource history.delete}" Click="DeleteRecord_Click" Padding="8,4" FontSize="12" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </TabItem>
      <TabItem Header="{DynamicResource history.completed}">
        <ListBox ItemsSource="{Binding CompletedJobs}" Margin="0,10,0,0">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Padding="8" Margin="0,0,0,8" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="6">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <StackPanel>
                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding StatusLine}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding ModelText}" ToolTip.Tip="{Binding ModelText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                  <Button Grid.Column="1" Content="{DynamicResource history.delete}" Click="DeleteRecord_Click" Padding="8,4" FontSize="12" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>
