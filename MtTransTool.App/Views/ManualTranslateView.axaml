<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MtTransTool.App.Views.ManualTranslateView">
  <Grid RowDefinitions="Auto,*,Auto,*" Margin="8" RowSpacing="8">
    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
      <TextBlock Text="{DynamicResource page.manual}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
      <Button Grid.Column="1" Content="{DynamicResource manual.loadSelected}" Command="{Binding UseSelectedCommand}" Padding="8,4" FontSize="12" />
      <Button Grid.Column="2" Classes="primary" Content="{DynamicResource manual.translate}" Command="{Binding TranslateCommand}" Padding="8,4" FontSize="12" />
    </Grid>

    <TextBox Grid.Row="1"
             Text="{Binding SourceText}"
             AcceptsReturn="True"
             TextWrapping="Wrap"
             Watermark="{DynamicResource manual.sourceWatermark}" />

    <TextBlock Grid.Row="2"
               Text="{Binding StatusText}"
               FontSize="12"
               Foreground="{DynamicResource TextSecondaryBrush}" />

    <Border Grid.Row="3" Background="{DynamicResource PreviewDialogBrush}" CornerRadius="6" Padding="10">
      <TextBox Text="{Binding TranslatedText}"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               Background="Transparent"
               BorderThickness="0"
               Foreground="{DynamicResource TextInverseBrush}" />
    </Border>
  </Grid>
</UserControl>
