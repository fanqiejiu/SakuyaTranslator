<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MtTransTool.App.Views.SettingsView">
  <UserControl.Styles>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.fieldLabel">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="Margin" Value="0,0,0,3" />
    </Style>
    <Style Selector="TextBox.smallInput">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="6,4" />
    </Style>
    <Style Selector="ComboBox.smallInput">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="6,3" />
    </Style>
    <Style Selector="CheckBox.compactCheck">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Margin" Value="0,1,0,1" />
    </Style>
    <Style Selector="TextBlock.helpText">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="LineHeight" Value="15" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="8" Spacing="8">
      <TextBlock Text="{DynamicResource page.settings}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />

      <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
        <StackPanel Spacing="8">
          <TextBlock Classes="sectionTitle" Text="{DynamicResource settings.section.translation}" />

          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="7" ColumnSpacing="8">
            <StackPanel>
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.translation.direction}" />
              <ComboBox Classes="smallInput" ItemsSource="{Binding TranslationPresetOptions}" SelectedItem="{Binding SelectedTranslationPresetOption}" />
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.translation.speed}" />
              <ComboBox Classes="smallInput" ItemsSource="{Binding SpeedPresetOptions}" SelectedItem="{Binding SelectedSpeedPresetOption}" />
            </StackPanel>
            <StackPanel Grid.Row="1">
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.translation.source}" />
              <ComboBox Classes="smallInput" ItemsSource="{Binding SourceLanguageOptions}" SelectedItem="{Binding SelectedSourceLanguage}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1">
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.translation.target}" />
              <ComboBox Classes="smallInput" ItemsSource="{Binding TargetLanguageOptions}" SelectedItem="{Binding SelectedTargetLanguage}" />
            </StackPanel>
          </Grid>

          <Border Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="5" Padding="7">
            <TextBlock Classes="helpText" Text="{Binding SpeedPresetDescription}" />
          </Border>

          <StackPanel Spacing="2">
            <TextBlock Classes="sectionTitle" Text="{DynamicResource settings.speed.advancedTitle}" />
            <TextBlock Classes="helpText" Text="{DynamicResource settings.speed.advancedHint}" />
          </StackPanel>

          <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" RowSpacing="7" ColumnSpacing="6">
            <StackPanel>
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.concurrency.files}" />
              <TextBox Classes="smallInput" Text="{Binding FileConcurrency}" IsEnabled="{Binding IsCustomSpeed}" />
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.concurrency.requests}" />
              <TextBox Classes="smallInput" Text="{Binding RequestConcurrency}" IsEnabled="{Binding IsCustomSpeed}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.concurrency.batch}" />
              <TextBox Classes="smallInput" Text="{Binding BatchSize}" IsEnabled="{Binding IsCustomSpeed}" />
            </StackPanel>
            <StackPanel Grid.Row="1">
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.concurrency.retry}" />
              <TextBox Classes="smallInput" Text="{Binding RetryCount}" IsEnabled="{Binding IsCustomSpeed}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1">
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.concurrency.interval}" />
              <TextBox Classes="smallInput" Text="{Binding RequestIntervalMs}" IsEnabled="{Binding IsCustomSpeed}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="2">
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.concurrency.timeout}" />
              <TextBox Classes="smallInput" Text="{Binding TimeoutSeconds}" IsEnabled="{Binding IsCustomSpeed}" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
        <StackPanel Spacing="8">
          <TextBlock Classes="sectionTitle" Text="{DynamicResource settings.section.interface}" />

          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="8">
            <StackPanel>
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.ui.language}" />
              <ComboBox Classes="smallInput" ItemsSource="{Binding UiCultures}" SelectedItem="{Binding SelectedUiCulture}" />
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.ui.theme}" />
              <ComboBox Classes="smallInput" ItemsSource="{Binding ThemeModeOptions}" SelectedItem="{Binding SelectedThemeModeOption}" />
            </StackPanel>
          </Grid>

          <StackPanel Spacing="2">
            <CheckBox Classes="compactCheck" Content="{DynamicResource settings.keepFormat}" IsChecked="{Binding Settings.PreserveJsonFormat}" />
            <CheckBox Classes="compactCheck" Content="{DynamicResource settings.autoBackup}" IsChecked="{Binding Settings.AutoBackup}" />
            <CheckBox Classes="compactCheck" Content="{DynamicResource settings.validatePlaceholders}" IsChecked="{Binding Settings.ValidatePlaceholders}" />
            <CheckBox Classes="compactCheck" Content="{DynamicResource settings.resumePrompt}" IsChecked="{Binding Settings.PromptResumeOnImport}" />
            <CheckBox Classes="compactCheck" Content="{DynamicResource settings.confirmDelete}" IsChecked="{Binding Settings.ConfirmBeforeDelete}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
        <StackPanel Spacing="7">
          <TextBlock Classes="sectionTitle" Text="{DynamicResource settings.section.experimental}" />
          <CheckBox Classes="compactCheck"
                    Content="{DynamicResource settings.experimental.proofread}"
                    IsChecked="{Binding EnableExperimentalProofread}" />
          <TextBlock Classes="helpText" Text="{DynamicResource settings.experimental.proofreadHint}" />
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
        <StackPanel Spacing="8">
          <TextBlock Classes="sectionTitle" Text="{DynamicResource settings.section.update}" />
          <CheckBox Classes="compactCheck" Content="{DynamicResource settings.update.startup}" IsChecked="{Binding Settings.CheckUpdatesOnStartup}" />

          <Grid ColumnDefinitions="104,*" RowDefinitions="Auto,Auto" RowSpacing="7" ColumnSpacing="8">
            <StackPanel>
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.update.frequency}" />
              <ComboBox Classes="smallInput" ItemsSource="{Binding UpdateFrequencyOptions}" SelectedItem="{Binding SelectedUpdateFrequency}" />
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Classes="fieldLabel" Text="{DynamicResource settings.update.repository}" />
              <TextBox Classes="smallInput" Text="{Binding Settings.GitHubRepository}" Watermark="owner/repo" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <WrapPanel>
        <Button Classes="primary" Content="{DynamicResource settings.save}" Command="{Binding SaveCommand}" Width="92" Padding="8,5" FontSize="12" Margin="0,0,8,6" />
        <TextBlock Text="{Binding SavedMessage}" VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}" FontSize="12" Margin="0,3,0,6" />
      </WrapPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
