<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MtTransTool.App.Views.ApiConfigView">
  <UserControl.Styles>
    <Style Selector="TextBlock.fieldLabel">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="Margin" Value="0,0,0,3" />
    </Style>
    <Style Selector="TextBox.smallInput">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="6,4" />
    </Style>
    <Style Selector="ComboBox.smallInput">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="6,3" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="8" RowDefinitions="Auto,*" RowSpacing="8">
    <TextBlock Text="{DynamicResource page.api}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
    <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <StackPanel>
              <TextBlock Classes="fieldLabel" Text="{DynamicResource api.provider}" />
              <ComboBox Classes="smallInput" ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProviderOption}" />
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Classes="fieldLabel" Text="{DynamicResource api.displayName}" />
              <TextBox Classes="smallInput" Text="{Binding DisplayName}" />
            </StackPanel>
          </Grid>

          <TextBlock Text="{Binding ProviderSubtitle}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="12"
                     TextWrapping="Wrap" />

          <WrapPanel IsVisible="{Binding HasProviderLinks}">
            <Button Content="{DynamicResource api.keyPlatform}"
                    Tag="{Binding ProviderApiKeyUrl}"
                    Click="OpenUrl_Click"
                    Padding="8,5"
                    FontSize="12"
                    Margin="0,0,6,4" />
            <Button Content="{DynamicResource api.docs}"
                    Tag="{Binding ProviderDocsUrl}"
                    Click="OpenUrl_Click"
                    Padding="8,5"
                    FontSize="12"
                    Margin="0,0,6,4" />
          </WrapPanel>

          <StackPanel>
            <TextBlock Classes="fieldLabel" Text="Base URL" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
              <TextBox Classes="smallInput" Text="{Binding BaseUrl}" Watermark="{DynamicResource api.baseUrl.watermark}" />
              <Button Grid.Column="1"
                      Content="{DynamicResource api.resetBaseUrl}"
                      Command="{Binding ResetBaseUrlCommand}"
                      Padding="8,4"
                      FontSize="12"
                      IsVisible="{Binding CanResetBaseUrl}" />
            </Grid>
          </StackPanel>

          <StackPanel>
            <TextBlock Classes="fieldLabel" Text="API Key" />
            <TextBox Classes="smallInput" Text="{Binding ApiKey}" PasswordChar="*" />
          </StackPanel>

          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
            <StackPanel>
              <TextBlock Classes="fieldLabel" Text="{DynamicResource api.model.saved}" />
              <ComboBox Classes="smallInput"
                        ItemsSource="{Binding SavedModelOptions}"
                        SelectedItem="{Binding SelectedSavedModel}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="{DynamicResource api.model.add}"
                    Command="{Binding AddModelCommand}"
                    Padding="8,4"
                    FontSize="12"
                    VerticalAlignment="Bottom" />
            <Button Grid.Column="2"
                    Content="{DynamicResource api.model.delete}"
                    Command="{Binding DeleteModelCommand}"
                    IsEnabled="{Binding CanDeleteSavedModel}"
                    Padding="8,4"
                    FontSize="12"
                    VerticalAlignment="Bottom" />
          </Grid>

          <StackPanel>
            <TextBlock Classes="fieldLabel" Text="{DynamicResource api.model}" />
            <TextBox Classes="smallInput" Text="{Binding Model}" Watermark="{Binding ModelHint}" />
          </StackPanel>

          <StackPanel>
            <TextBlock Classes="fieldLabel" Text="{DynamicResource api.localModel}" />
            <TextBox Classes="smallInput" Text="{Binding LocalModelPath}" Watermark="{DynamicResource api.localModel.watermark}" />
          </StackPanel>

          <TextBlock Text="{Binding StatusText}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="12"
                     TextWrapping="Wrap" />

          <WrapPanel>
            <Button Classes="primary" Content="{DynamicResource api.save}" Command="{Binding SaveCommand}" Width="92" Padding="8,5" FontSize="12" Margin="0,0,8,4" />
            <Button Content="{DynamicResource api.test}" Command="{Binding TestCommand}" Width="92" Padding="8,5" FontSize="12" Margin="0,0,8,4" />
          </WrapPanel>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
