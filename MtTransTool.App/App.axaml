<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MtTransTool.App.ViewModels"
             xmlns:views="using:MtTransTool.App.Views"
             x:Class="MtTransTool.App.App">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F7FB" />
          <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#EAF0F7" />
          <SolidColorBrush x:Key="SidebarBorderBrush" Color="#D6DFEA" />
          <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="SurfaceBrush" Color="#F8FAFC" />
          <SolidColorBrush x:Key="SurfaceStrongBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#EEF3F8" />
          <SolidColorBrush x:Key="BorderSoftBrush" Color="#D9E1EA" />
          <SolidColorBrush x:Key="TextPrimaryBrush" Color="#243044" />
          <SolidColorBrush x:Key="TextSecondaryBrush" Color="#58677A" />
          <SolidColorBrush x:Key="TextInverseBrush" Color="#F8FAFC" />
          <SolidColorBrush x:Key="AccentBrush" Color="#1F7A8C" />
          <SolidColorBrush x:Key="AccentHoverBrush" Color="#176A7A" />
          <SolidColorBrush x:Key="NavHoverBrush" Color="#DDE8F3" />
          <SolidColorBrush x:Key="NavPressedBrush" Color="#CEDDEA" />
          <SolidColorBrush x:Key="PreviewDialogBrush" Color="#1F2937" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="AppBackgroundBrush" Color="#151A23" />
          <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#182131" />
          <SolidColorBrush x:Key="SidebarBorderBrush" Color="#273246" />
          <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#111823" />
          <SolidColorBrush x:Key="SurfaceBrush" Color="#1A2433" />
          <SolidColorBrush x:Key="SurfaceStrongBrush" Color="#202C3D" />
          <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#172030" />
          <SolidColorBrush x:Key="BorderSoftBrush" Color="#2E3B50" />
          <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E6EDF5" />
          <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B6C8" />
          <SolidColorBrush x:Key="TextInverseBrush" Color="#F8FAFC" />
          <SolidColorBrush x:Key="AccentBrush" Color="#2AB7A9" />
          <SolidColorBrush x:Key="AccentHoverBrush" Color="#35C9BA" />
          <SolidColorBrush x:Key="NavHoverBrush" Color="#233149" />
          <SolidColorBrush x:Key="NavPressedBrush" Color="#2B3B55" />
          <SolidColorBrush x:Key="PreviewDialogBrush" Color="#0C111A" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.DataTemplates>
    <DataTemplate DataType="{x:Type vm:TranslateQueueViewModel}">
      <views:TranslateQueueView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PreviewViewModel}">
      <views:PreviewView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:LivePreviewViewModel}">
      <views:LivePreviewView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ManualTranslateViewModel}">
      <views:ManualTranslateView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ApiConfigViewModel}">
      <views:ApiConfigView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
      <views:HistoryView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
      <views:SettingsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:AboutViewModel}">
      <views:AboutView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:TemplatesViewModel}">
      <views:TemplatesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:LogsViewModel}">
      <views:LogsView />
    </DataTemplate>
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
    <Style Selector="Button.primary">
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
  </Application.Styles>
</Application>
