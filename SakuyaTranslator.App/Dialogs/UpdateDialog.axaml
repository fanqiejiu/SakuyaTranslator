<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SakuyaTranslator.App.Dialogs.UpdateDialog"
        Width="520"
        Height="420"
        MinWidth="420"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Title="更新检查"
        FontFamily="Inter, Microsoft YaHei UI, Segoe UI">
  <Grid Margin="18" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
    <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
    <TextBlock x:Name="MetaText" Grid.Row="1" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
    <TextBox x:Name="ChangelogText"
             Grid.Row="2"
             AcceptsReturn="True"
             IsReadOnly="True"
             TextWrapping="Wrap" />
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="稍后提醒" Click="Close_Click" />
      <Button x:Name="DownloadButton" Content="打开下载页" Click="OpenDownload_Click" />
      <Button x:Name="CopyButton" Content="复制下载链接" Click="CopyDownload_Click" />
    </StackPanel>
  </Grid>
</Window>
