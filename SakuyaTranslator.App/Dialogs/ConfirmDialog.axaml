<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SakuyaTranslator.App.Dialogs.ConfirmDialog"
        Width="380"
        Height="190"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="确认操作"
        FontFamily="Inter, Microsoft YaHei UI, Segoe UI">
  <Grid Margin="18" RowDefinitions="Auto,*,Auto" RowSpacing="12">
    <TextBlock x:Name="TitleText" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" />
    <TextBlock x:Name="BodyText" Grid.Row="1" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" />
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button x:Name="CancelButton" Content="{DynamicResource dialog.cancel}" Click="Cancel_Click" />
      <Button x:Name="ConfirmButton" Content="确认" Click="Confirm_Click" />
    </StackPanel>
  </Grid>
</Window>
