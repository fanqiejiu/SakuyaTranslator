<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:SakuyaTranslator.App.Controls"
             x:Class="SakuyaTranslator.App.Views.TranslateQueueView">
  <UserControl.Styles>
    <Style Selector="Button.modeSwitch">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Background" Value="{DynamicResource SurfaceStrongBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.modeSwitch.selected">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="8">
    <Grid RowDefinitions="Auto,*"
          RowSpacing="8"
          IsVisible="{Binding IsDirectoryVisible}">
      <Border Background="{DynamicResource SurfaceBrush}"
              BorderBrush="{DynamicResource BorderSoftBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Padding="8">
        <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
          <WrapPanel>
            <Button Classes="primary" Content="{DynamicResource queue.add}" Click="AddJson_Click" Padding="8,4" FontSize="12" Margin="0,0,5,5" />
            <Button Content="{DynamicResource queue.folder}" Click="AddFolder_Click" Padding="8,4" FontSize="12" Margin="0,0,5,5" />
            <Button Content="{DynamicResource queue.startQueue}" Command="{Binding StartQueueCommand}" Padding="8,4" FontSize="12" Margin="0,0,5,5" />
            <Button Content="{DynamicResource queue.pauseQueue}" Command="{Binding PauseCommand}" Padding="8,4" FontSize="12" Margin="0,0,5,5" />
            <Button Content="{DynamicResource queue.stopQueue}" Command="{Binding StopCommand}" Padding="8,4" FontSize="12" Margin="0,0,5,5" />
          </WrapPanel>
          <TextBlock Grid.Row="1"
                     Text="JSON / CSV / SRT / TXT"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="11" />
        </Grid>
      </Border>

      <ListBox Grid.Row="1"
               ItemsSource="{Binding Jobs}"
               SelectedItem="{Binding SelectedJob}"
               Background="{DynamicResource SurfaceBrush}"
               BorderBrush="{DynamicResource BorderSoftBrush}"
               BorderThickness="1"
               CornerRadius="8">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Margin="4"
                    Padding="8"
                    Background="{DynamicResource SurfaceStrongBrush}"
                    BorderBrush="{DynamicResource BorderSoftBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    PointerPressed="OpenJobDetail_Click">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto" RowSpacing="5" ColumnSpacing="8">
                <TextBlock Text="{Binding FileName}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           Text="{Binding TranslationDirection}"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <Button Grid.Column="2"
                        Content="{DynamicResource queue.delete}"
                        Click="DeleteJob_Click"
                        Padding="7,3"
                        FontSize="11" />
                <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,42" ColumnSpacing="8">
                  <controls:PipeProgressBar Value="{Binding ProgressPercent}"
                                            Status="{Binding Status}"
                                            ShowPercent="False"
                                            Height="16" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding ProgressPercentText}"
                             FontSize="11"
                             FontWeight="SemiBold"
                             TextAlignment="Right"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                </Grid>
                <Grid Grid.Row="2"
                      Grid.ColumnSpan="3"
                      ColumnDefinitions="Auto,Auto,Auto,Auto"
                      ColumnSpacing="8">
                  <TextBlock Text="{Binding Status}"
                             FontSize="12"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding CompletedRatioText}"
                             FontSize="12"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding ErrorCountText}"
                             MinWidth="44"
                             FontSize="12"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Grid.Column="3"
                             Text="{Binding WarningCountText}"
                             MinWidth="48"
                             FontSize="12"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                </Grid>
                <TextBlock Grid.Row="3"
                           Grid.ColumnSpan="3"
                           Text="{Binding ModelText}"
                           ToolTip.Tip="{Binding ModelText}"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>

    <Grid RowDefinitions="Auto,Auto,*"
          RowSpacing="8"
          IsVisible="{Binding IsDetailVisible}">
      <Border Background="{DynamicResource SurfaceBrush}"
              BorderBrush="{DynamicResource BorderSoftBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Padding="8">
        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="7">
          <WrapPanel>
            <Button Content="{DynamicResource queue.back}" Command="{Binding BackToDirectoryCommand}" Padding="8,4" FontSize="12" Margin="0,0,5,5" />
            <Button Content="{DynamicResource queue.startCurrent}" Command="{Binding StartQueueCommand}" Padding="8,4" FontSize="12" Margin="0,0,5,5" />
            <Button Content="{DynamicResource queue.pauseCurrent}" Command="{Binding PauseCommand}" Padding="8,4" FontSize="12" Margin="0,0,5,5" />
            <Button Content="{DynamicResource queue.stopCurrent}" Command="{Binding StopCommand}" Padding="8,4" FontSize="12" Margin="0,0,5,5" />
            <Button Content="{DynamicResource queue.save}" Command="{Binding SaveProjectCommand}" Padding="8,4" FontSize="12" Margin="0,0,5,5" />
            <Button Content="{DynamicResource queue.export}" Command="{Binding ExportSelectedCommand}" Padding="8,4" FontSize="12" Margin="0,0,5,5" />
            <Button Content="{DynamicResource queue.delete}" Click="DeleteSelectedJob_Click" Padding="8,4" FontSize="12" Margin="0,0,5,5" />
          </WrapPanel>
          <TextBlock Grid.Row="1"
                     Text="{Binding SelectedJob.FileName}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="12"
                     TextTrimming="CharacterEllipsis" />
          <Grid Grid.Row="2" ColumnDefinitions="Auto,*,*,*" ColumnSpacing="6">
            <TextBlock Text="{DynamicResource queue.mode}"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <Grid Grid.Column="1">
              <Button Classes="modeSwitch selected"
                      Content="{DynamicResource queue.detail}"
                      ToolTip.Tip="{DynamicResource queue.detail.full}"
                      Command="{Binding ShowEntryGridCommand}"
                      IsVisible="{Binding IsEntryGridModeSelected}" />
              <Button Classes="modeSwitch"
                      Content="{DynamicResource queue.detail}"
                      ToolTip.Tip="{DynamicResource queue.detail.full}"
                      Command="{Binding ShowEntryGridCommand}"
                      IsVisible="{Binding !IsEntryGridModeSelected}" />
            </Grid>
            <Grid Grid.Column="2">
              <Button Classes="modeSwitch selected"
                      Content="{DynamicResource queue.live}"
                      ToolTip.Tip="{DynamicResource queue.live.full}"
                      Command="{Binding ShowLiveDetailCommand}"
                      IsVisible="{Binding IsLiveDetailModeSelected}" />
              <Button Classes="modeSwitch"
                      Content="{DynamicResource queue.live}"
                      ToolTip.Tip="{DynamicResource queue.live.full}"
                      Command="{Binding ShowLiveDetailCommand}"
                      IsVisible="{Binding !IsLiveDetailModeSelected}" />
            </Grid>
            <Grid Grid.Column="3" IsVisible="{Binding IsProofreadEntryVisible}">
              <Button Classes="modeSwitch selected"
                      Content="{DynamicResource queue.proofread}"
                      ToolTip.Tip="{DynamicResource queue.proofread.full}"
                      Command="{Binding ShowProofreadCommand}"
                      IsVisible="{Binding IsProofreadModeSelected}" />
              <Button Classes="modeSwitch"
                      Content="{DynamicResource queue.proofread}"
                      ToolTip.Tip="{DynamicResource queue.proofread.full}"
                      Command="{Binding ShowProofreadCommand}"
                      IsVisible="{Binding !IsProofreadModeSelected}" />
            </Grid>
          </Grid>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              IsVisible="{Binding HasQueueNotice}"
              Background="{DynamicResource SurfaceStrongBrush}"
              BorderBrush="{DynamicResource BorderSoftBrush}"
              BorderThickness="1"
              CornerRadius="5"
              Padding="7,5">
        <TextBlock Text="{Binding QueueNotice}"
                   FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap"
                   TextTrimming="CharacterEllipsis" />
      </Border>

      <DataGrid Grid.Row="2"
                IsVisible="{Binding IsEntryGridVisible}"
                ItemsSource="{Binding SelectedEntries}"
                SelectedItem="{Binding SelectedEntry}"
                AutoGenerateColumns="False"
                CanUserResizeColumns="True"
                CanUserSortColumns="True"
                HorizontalScrollBarVisibility="Visible"
                VerticalScrollBarVisibility="Auto"
                GridLinesVisibility="Horizontal"
                BorderBrush="{DynamicResource BorderSoftBrush}"
                BorderThickness="1"
                RowHeight="30">
        <DataGrid.Columns>
          <DataGridTextColumn Header="{DynamicResource grid.status}" Binding="{Binding Status}" Width="58" IsReadOnly="True" />
          <DataGridTextColumn Header="{DynamicResource grid.source}" Binding="{Binding SourceText}" Width="520" IsReadOnly="True" />
          <DataGridTextColumn Header="{DynamicResource grid.translation}" Binding="{Binding TranslationText, Mode=TwoWay}" Width="620" />
        </DataGrid.Columns>
      </DataGrid>

      <Grid Grid.Row="2"
            RowDefinitions="Auto,*"
            RowSpacing="8"
            IsVisible="{Binding IsLiveDetailVisible}">
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderSoftBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8">
          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
              <TextBlock Text="{DynamicResource queue.live}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Grid.Column="1"
                         Text="{Binding LiveCurrentFile}"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         TextTrimming="CharacterEllipsis" />
            </Grid>
            <TextBlock Grid.Row="1"
                       Text="{Binding LiveStatusLine}"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis" />
            <Grid Grid.Row="2" ColumnDefinitions="*,42" ColumnSpacing="8">
              <controls:PipeProgressBar Value="{Binding LiveProgressPercent}"
                                        Status="{Binding SelectedJob.Status}"
                                        ShowPercent="False"
                                        Height="16" />
              <TextBlock Grid.Column="1"
                         Text="{Binding LiveProgressPercentText}"
                         FontSize="11"
                         FontWeight="SemiBold"
                         TextAlignment="Right"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </Grid>
          </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#050A0F"
                BorderBrush="#1F7A8C"
                BorderThickness="1"
                CornerRadius="8"
                Padding="0">
          <Grid RowDefinitions="Auto,*,*">
            <Border Background="#101923"
                    BorderBrush="#1F7A8C"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0"
                    Padding="10,6">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="7">
                <TextBlock Text="●"
                           Foreground="#E15A5A"
                           FontSize="11"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{DynamicResource queue.live.terminalTitle}"
                           Foreground="#D9F8EF"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2"
                           Text="{Binding LiveEntryStatus}"
                           Foreground="#7CFFCB"
                           FontSize="11"
                           FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI" />
              </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="10,10,10,5"
                    Background="#071018"
                    BorderBrush="#163947"
                    BorderThickness="1"
                    CornerRadius="6"
                    MinHeight="112">
              <Grid RowDefinitions="Auto,*">
                <Border Background="#0D1A24"
                        BorderBrush="#163947"
                        BorderThickness="0,0,0,1"
                        CornerRadius="6,6,0,0"
                        Padding="8,4">
                  <TextBlock Text="{DynamicResource live.sourceStream}"
                             Foreground="#95B8FF"
                             FontSize="11"
                             FontWeight="SemiBold"
                             FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI" />
                </Border>
                <ScrollViewer Grid.Row="1"
                              Padding="10,8"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <TextBlock Text="{Binding LiveSourceStreamText}"
                             Foreground="#C9E6FF"
                             FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI"
                             FontSize="12"
                             LineHeight="20"
                             TextWrapping="Wrap" />
                </ScrollViewer>
              </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="10,5,10,10"
                    Background="#06120D"
                    BorderBrush="#1E5B45"
                    BorderThickness="1"
                    CornerRadius="6"
                    MinHeight="112">
              <Grid RowDefinitions="Auto,*">
                <Border Background="#0A2118"
                        BorderBrush="#1E5B45"
                        BorderThickness="0,0,0,1"
                        CornerRadius="6,6,0,0"
                        Padding="8,4">
                  <TextBlock Text="{DynamicResource live.translationStream}"
                             Foreground="#7CFFCB"
                             FontSize="11"
                             FontWeight="SemiBold"
                             FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI" />
                </Border>
                <ScrollViewer Grid.Row="1"
                              Padding="10,8"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <TextBlock Text="{Binding LiveTranslationStreamText}"
                             Foreground="#A9FFD9"
                             FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI"
                             FontSize="12"
                             LineHeight="20"
                             TextWrapping="Wrap" />
                </ScrollViewer>
              </Grid>
            </Border>
          </Grid>
        </Border>
      </Grid>

      <Grid Grid.Row="2"
            RowDefinitions="Auto,*"
            RowSpacing="8"
            IsVisible="{Binding IsProofreadPanelVisible}">
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderSoftBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="7">
            <TextBlock Text="{Binding ProofreadReadinessText}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12"
                       TextWrapping="Wrap" />
            <WrapPanel Grid.Row="1">
              <Button Classes="primary"
                      Content="{DynamicResource proof.ruleRun}"
                      Command="{Binding RunRuleProofreadCommand}"
                      IsEnabled="{Binding IsProofreadAvailable}"
                      Padding="8,4"
                      FontSize="12"
                      Margin="0,0,5,5" />
              <Button Content="{DynamicResource proof.aiRun}"
                      Command="{Binding RunAiProofreadCommand}"
                      IsEnabled="{Binding IsProofreadAvailable}"
                      Padding="8,4"
                      FontSize="12"
                      Margin="0,0,5,5" />
              <Button Content="{DynamicResource proof.cancel}"
                      Command="{Binding CancelProofreadCommand}"
                      Padding="8,4"
                      FontSize="12"
                      Margin="0,0,5,5" />
              <Button Content="{DynamicResource proof.apply}"
                      Command="{Binding ApplyProofreadSuggestionCommand}"
                      IsEnabled="{Binding SelectedProofreadIssue.HasReplacement}"
                      Padding="8,4"
                      FontSize="12"
                      Margin="0,0,5,5" />
            </WrapPanel>
            <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
              <TextBlock Text="{DynamicResource proof.model}"
                         VerticalAlignment="Center"
                         FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <ComboBox Grid.Column="1"
                        ItemsSource="{Binding ProofreadModelOptions}"
                        SelectedItem="{Binding SelectedProofreadModel}"
                        IsEnabled="{Binding IsProofreadAvailable}"
                        MinHeight="28"
                        FontSize="12">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Spacing="1">
                      <TextBlock Text="{Binding DisplayName}"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding DetailText}"
                                 FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Grid.Column="2"
                         Text="{Binding ProofreadSummaryText}"
                         VerticalAlignment="Center"
                         FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </Grid>
            <TextBlock Grid.Row="3"
                       Text="{Binding ProofreadModelHelpText}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"
                       TextWrapping="Wrap" />
          </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="2*,*" ColumnSpacing="8">
          <Grid RowDefinitions="Auto,*" RowSpacing="6">
            <TextBlock Text="{Binding ProofreadStatus}"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis" />
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding ProofreadIssues}"
                      SelectedItem="{Binding SelectedProofreadIssue}"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="{DynamicResource BorderSoftBrush}"
                      BorderThickness="1"
                      RowHeight="30">
              <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource proof.severity}" Binding="{Binding Severity}" Width="56" IsReadOnly="True" />
                <DataGridTextColumn Header="{DynamicResource proof.origin}" Binding="{Binding Origin}" Width="48" IsReadOnly="True" />
                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="44" IsReadOnly="True" />
                <DataGridTextColumn Header="{DynamicResource proof.category}" Binding="{Binding Category}" Width="96" IsReadOnly="True" />
                <DataGridTextColumn Header="{DynamicResource proof.message}" Binding="{Binding Message}" Width="*" IsReadOnly="True" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>

          <Border Grid.Column="1"
                  Background="{DynamicResource SurfaceBrush}"
                  BorderBrush="{DynamicResource BorderSoftBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <Grid RowDefinitions="Auto,*,Auto,*,Auto,*,Auto,*" RowSpacing="6">
                <TextBlock Text="{DynamicResource proof.source}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBox Grid.Row="1"
                         Text="{Binding SelectedProofreadIssue.SourceText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MinHeight="62"
                         FontSize="12" />
                <TextBlock Grid.Row="2"
                           Text="{DynamicResource proof.translation}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBox Grid.Row="3"
                         Text="{Binding SelectedProofreadIssue.TranslationText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MinHeight="62"
                         FontSize="12" />
                <TextBlock Grid.Row="4"
                           Text="{DynamicResource proof.suggestion}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBox Grid.Row="5"
                         Text="{Binding SelectedProofreadIssue.Suggestion, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MinHeight="62"
                         FontSize="12" />
                <TextBlock Grid.Row="6"
                           Text="{DynamicResource proof.replacement}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBox Grid.Row="7"
                         Text="{Binding SelectedProofreadIssue.ReplacementText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MinHeight="62"
                         FontSize="12" />
              </Grid>
            </ScrollViewer>
          </Border>
        </Grid>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
